# ---------------------------------------------------------------------------
# Example environment for local development.
#
#   cp .env.example .env    # then adjust as needed
#
# Config precedence (libs/config, figment):  defaults -> config/{RUN_ENV}.toml -> env
# Every var below overrides the layered TOML. Prefix is APP, nested separator is `__`.
# Values here assume the docker-compose stack (`just up`) with host-published ports.
# ---------------------------------------------------------------------------

# Selects config/{RUN_ENV}.toml. Use `local` for dev, `production` in prod.
RUN_ENV=local

# ---- Server bind addresses -------------------------------------------------
# Defaults shown are the `gateway` ports. Each service overrides these per its
# row in docs/CONVENTIONS.md:
#   gateway      http 8080            metrics 9100
#   identity     health 8081  grpc 50051  metrics 9101
#   ledger       health 8082  grpc 50052  metrics 9102
#   notification ws/health 8083       metrics 9103
#   worker       health 8084          metrics 9104
APP__SERVER__HTTP_ADDR=0.0.0.0:8080
APP__SERVER__GRPC_ADDR=0.0.0.0:50051
APP__SERVER__METRICS_ADDR=0.0.0.0:9100

# ---- Database (one per bounded context: identity_db, ledger_db, worker_db) --
# Point at the db this service owns. `notification` is stateless (no DB).
# Local compose exposes Postgres on localhost:5432 (user/pass: app/app).
APP__DATABASE__URL=postgres://app:app@localhost:5432/ledger_db
APP__DATABASE__MAX_CONNECTIONS=20

# ---- Redis -----------------------------------------------------------------
APP__REDIS__URL=redis://localhost:6379

# ---- Kafka / Redpanda ------------------------------------------------------
APP__KAFKA__BROKERS=localhost:9092

# ---- OpenTelemetry ---------------------------------------------------------
APP__OTEL__ENDPOINT=http://localhost:4317
# Set per service (gateway|identity|ledger|notification|worker).
APP__OTEL__SERVICE_NAME=ledger

# ---- JWT / auth ------------------------------------------------------------
APP__JWT__ISSUER=https://identity.local
APP__JWT__ACCESS_TTL_SECONDS=900
APP__JWT__REFRESH_TTL_SECONDS=2592000

# ---- Logging ---------------------------------------------------------------
# level: trace|debug|info|warn|error   format: json|pretty
APP__LOG__LEVEL=info
APP__LOG__FORMAT=json

# ---- sqlx ------------------------------------------------------------------
# Uncomment to build against the committed offline query cache (.sqlx/) without a live DB.
# SQLX_OFFLINE=true
# DATABASE_URL is what the sqlx CLI (migrations, prepare) reads — keep in sync with the app URL.
DATABASE_URL=postgres://app:app@localhost:5432/ledger_db
